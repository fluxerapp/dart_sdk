# Fluxer SDK integration test credentials
# Copy this file to .env and fill in your values
# .env is gitignored and will not be committed

# Option 1: Direct token (use for live API with captcha protection)
FLUXER_TEST_TOKEN=

# Option 2: Email/password login (use for staging/local APIs without captcha)
FLUXER_TEST_EMAIL=
FLUXER_TEST_PASSWORD=

# API base URL (defaults to https://api.fluxer.app/v1)
FLUXER_TEST_BASE_URL=https://api.fluxer.app/v1
